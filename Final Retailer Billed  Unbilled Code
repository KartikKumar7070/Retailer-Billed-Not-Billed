import pandas as pd
import numpy as np
from datetime import datetime
import warnings
import os
import gc

warnings.filterwarnings('ignore')

# ============================================================
# CONFIGURATION
# ============================================================
FILE_PATHS = [
    '/content/12.BPOS BILLING REPORT SUMMARY _MAR-26.xlsx',
    '/content/13.BPOS BILLING REPORT SUMMARY _APR-26.xlsx',
    '/content/14.BPOS BILLING REPORT SUMMARY _MAY-26.xlsx'
]

OUTPUT_FILE = f'/content/Billed_NotBilled_Summary_{datetime.now().strftime("%Y%m%d_%H%M")}.xlsx'

# ============================================================
# STEP 1: LOAD ALL FILES
# ============================================================
print("=" * 60)
print("LOADING FILES")
print("=" * 60)

all_data = []
for i, fp in enumerate(FILE_PATHS, 1):
    print(f"\n[{i}/3] Loading: {os.path.basename(fp)}")
    df_temp = pd.read_excel(fp, header=1, engine='openpyxl')
    all_data.append(df_temp)
    print(f"  ✓ Loaded: {len(df_temp):,} rows")

df = pd.concat(all_data, ignore_index=True, copy=False)
del all_data
gc.collect()

print(f"\n🔥 TOTAL: {len(df):,} rows")
print(f"📋 Original columns: {list(df.columns)}")

# ============================================================
# STEP 2: CLEAN & RENAME COLUMNS (HANDLE DUPLICATES)
# ============================================================
df.columns = df.columns.str.strip()

# Print original columns for debugging
print(f"\n🔍 Columns after strip: {list(df.columns)}")

# FIX: Handle duplicate DB ID columns - drop the .1 version
db_id_cols = [c for c in df.columns if 'DB' in c.upper() and 'ID' in c.upper()]
print(f"🔍 DB ID columns found: {db_id_cols}")

if len(db_id_cols) > 1:
    for dup_col in db_id_cols[1:]:
        print(f"⚠️ Dropping duplicate column: {dup_col}")
        df = df.drop(columns=[dup_col])

# FIX: Handle duplicate 'state' column (lowercase)
state_cols = [c for c in df.columns if c.upper() == 'STATE']
if len(state_cols) > 1:
    for dup_col in state_cols[1:]:
        print(f"⚠️ Dropping duplicate column: {dup_col}")
        df = df.drop(columns=[dup_col])

print(f"\n📋 Columns after dedup: {list(df.columns)}")

# Now create rename mapping
rename_map = {
    'DSM CODE': 'DSM_CODE', 'RESOURCE NAME': 'RESOURCE_NAME',
    'DB ID': 'DB_ID', 'DISTRIBUTOR': 'DISTRIBUTOR',
    'BEAT CODE': 'BEAT_CODE', 'BEAT NAME': 'BEAT_NAME',
    'RETAILER ID': 'RETAILER_ID', 'RETAILER': 'RETAILER',
    'INVOICE DATE': 'INVOICE_DATE',
    'AMOUNT (WITH TAX)': 'AMOUNT_WITH_TAX',
    'AMOUNT (PRE TAX)': 'AMOUNT_PRE_TAX',
    'REGION': 'REGION', 'NSM': 'NSM', 'ZSM': 'ZSM',
    'STATE': 'STATE', 'ASM NAME': 'ASM_NAME',
    'SO NAME': 'SO_NAME', 'DISTRICT': 'DISTRICT',
    'CITY': 'CITY', 'DB NAME': 'DB_NAME'
}

# Only rename columns that exist
df = df.rename(columns={k: v for k, v in rename_map.items() if k in df.columns})

print(f"\n📋 Columns after rename: {list(df.columns)}")

# Check critical columns
critical_cols = ['NSM', 'REGION', 'STATE', 'ZSM', 'ASM_NAME', 'SO_NAME', 'DISTRICT', 'CITY', 'DB_ID', 'DB_NAME']
for col in critical_cols:
    if col not in df.columns:
        print(f"⚠️ WARNING: {col} not found! Creating empty column.")
        df[col] = ''
    else:
        print(f"✓ {col} found")

# Parse dates
df['INVOICE_DATE'] = pd.to_datetime(df['INVOICE_DATE'], errors='coerce')
df = df.dropna(subset=['INVOICE_DATE'])

# Clean amounts
for col in ['AMOUNT_WITH_TAX', 'AMOUNT_PRE_TAX']:
    if col in df.columns:
        df[col] = df[col].astype(str).str.replace(',', '').str.strip()
        df[col] = pd.to_numeric(df[col], errors='coerce').fillna(0)

# ============================================================
# FIX 1: CHRONOLOGICAL MONTH ORDERING
# ============================================================
print(f"\n{'='*60}")
print(f"FIXING MONTH ORDER (Chronological)")
print(f"{'='*60}")

df['Month_Num'] = df['INVOICE_DATE'].dt.month
df['Year'] = df['INVOICE_DATE'].dt.year
df['Month_Year'] = df['INVOICE_DATE'].dt.strftime("%b'%y").str.upper()

month_order = {
    "JAN'25": 1, "FEB'25": 2, "MAR'25": 3, "APR'25": 4, "MAY'25": 5, "JUN'25": 6,
    "JUL'25": 7, "AUG'25": 8, "SEP'25": 9, "OCT'25": 10, "NOV'25": 11, "DEC'25": 12,
    "JAN'26": 13, "FEB'26": 14, "MAR'26": 15, "APR'26": 16, "MAY'26": 17, "JUN'26": 18,
    "JUL'26": 19, "AUG'26": 20, "SEP'26": 21, "OCT'26": 22, "NOV'26": 23, "DEC'26": 24
}

df = df.sort_values(['Year', 'Month_Num'])
actual_months = sorted(df['Month_Year'].unique(), key=lambda x: month_order.get(x, 99))
print(f"✓ Months in chronological order: {actual_months}")

# ============================================================
# STEP 3: CREATE STANDARDIZED NAME LOOKUPS
# ============================================================
print(f"\n{'='*60}")
print(f"CREATING STANDARDIZED NAME LOOKUPS")
print(f"{'='*60}")

emp_freq = df.groupby(['DSM_CODE', 'RESOURCE_NAME'], dropna=False).size().reset_index(name='COUNT')
emp_std = emp_freq.sort_values('COUNT', ascending=False).drop_duplicates('DSM_CODE', keep='first')
emp_lookup = emp_std[['DSM_CODE', 'RESOURCE_NAME']].rename(columns={'RESOURCE_NAME': 'STD_EMP_NAME'})

beat_freq = df.groupby(['BEAT_CODE', 'BEAT_NAME'], dropna=False).size().reset_index(name='COUNT')
beat_std = beat_freq.sort_values('COUNT', ascending=False).drop_duplicates('BEAT_CODE', keep='first')
beat_lookup = beat_std[['BEAT_CODE', 'BEAT_NAME']].rename(columns={'BEAT_NAME': 'STD_BEAT_NAME'})

ret_freq = df.groupby(['RETAILER_ID', 'RETAILER'], dropna=False).size().reset_index(name='COUNT')
ret_std = ret_freq.sort_values('COUNT', ascending=False).drop_duplicates('RETAILER_ID', keep='first')
ret_lookup = ret_std[['RETAILER_ID', 'RETAILER']].rename(columns={'RETAILER': 'STD_RET_NAME'})

print(f"✓ Employee lookups: {len(emp_lookup):,}")
print(f"✓ Beat lookups: {len(beat_lookup):,}")
print(f"✓ Retailer lookups: {len(ret_lookup):,}")

# ============================================================
# STEP 4: MERGE STANDARDIZED NAMES TO DATA
# ============================================================
df = df.merge(emp_lookup, on='DSM_CODE', how='left')
df = df.merge(beat_lookup, on='BEAT_CODE', how='left')
df = df.merge(ret_lookup, on='RETAILER_ID', how='left')

print(f"✓ Standardized names added to all {len(df):,} rows")

# ============================================================
# STEP 5: VERIFY DUMP TOTALS
# ============================================================
print(f"\n{'='*60}")
print(f"VERIFYING DUMP TOTALS")
print(f"{'='*60}")

dump_total = df['AMOUNT_PRE_TAX'].sum()
print(f"💰 TOTAL DUMP AMOUNT (PRE-TAX): {dump_total:,.0f}")

monthly_dump_totals = df.groupby('Month_Year', dropna=False)['AMOUNT_PRE_TAX'].sum().sort_index()
for month, total in monthly_dump_totals.items():
    print(f"   {month}: {total:,.0f}")

# ============================================================
# STEP 6: BUILD RETAILER MASTER (NO DEDUPLICATION - as-is)
# ============================================================
print(f"\n{'='*60}")
print(f"BUILDING RETAILER MASTER (as-is, multiple rows if mapping differs)")
print(f"{'='*60}")

# Group by ALL mapping columns - if mapping same, 1 row; if mapping changes, multiple rows
retailer_groupby_cols = ['RETAILER_ID', 'STD_RET_NAME', 'DSM_CODE', 'STD_EMP_NAME',
                          'BEAT_CODE', 'STD_BEAT_NAME', 'DB_ID', 'DB_NAME', 'DISTRIBUTOR',
                          'ZSM', 'ASM_NAME', 'SO_NAME', 'REGION', 'STATE', 'DISTRICT', 'CITY']
retailer_groupby_cols = [c for c in retailer_groupby_cols if c in df.columns]
print(f"✓ Retailer groupby columns: {retailer_groupby_cols}")

# Aggregate by full combination - natural deduplication via groupby
retailer_agg = df.groupby(retailer_groupby_cols, dropna=False).agg({
    'AMOUNT_PRE_TAX': 'sum',
    'INVOICE_DATE': 'count'
}).reset_index().rename(columns={'INVOICE_DATE': 'TRANSACTION_COUNT'})

print(f"✓ Retailer combinations: {len(retailer_agg):,} rows")
print(f"✓ Total pre-tax sales: {retailer_agg['AMOUNT_PRE_TAX'].sum():,.0f}")

# ============================================================
# STEP 7: BUILD MONTHLY PIVOT BY RETAILER COMBINATION
# ============================================================
print(f"\n{'='*60}")
print(f"BUILDING MONTHLY PIVOT BY RETAILER COMBINATION")
print(f"{'='*60}")

monthly_agg = df.groupby(retailer_groupby_cols + ['Month_Year'], dropna=False)['AMOUNT_PRE_TAX'].sum().reset_index()
monthly_pivot = monthly_agg.pivot(index=retailer_groupby_cols, columns='Month_Year', values='AMOUNT_PRE_TAX').fillna(0)

for month in actual_months:
    if month not in monthly_pivot.columns:
        monthly_pivot[month] = 0

monthly_pivot = monthly_pivot[actual_months]
monthly_pivot['TOTAL_BILLING'] = monthly_pivot.sum(axis=1)

# Verify monthly pivot total matches dump total
monthly_pivot_total = monthly_pivot['TOTAL_BILLING'].sum()
print(f"✓ Monthly Pivot Total: {monthly_pivot_total:,.0f}")
print(f"✓ Match with Dump: {'✅ PERFECT' if abs(monthly_pivot_total - dump_total) < 1 else '❌ MISMATCH'}")

# ============================================================
# STEP 8: BUILD ALL 6 SUMMARY SHEETS
# ============================================================
