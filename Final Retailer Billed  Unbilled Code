beat_final['TOTAL BILLING'] = beat_summary['TOTAL_BILLING']
beat_final['EMP STATUS'] = ''
beat_final['BEAT STATUS'] = ''

beat_sheet_total = beat_final['TOTAL BILLING'].sum()
print(f"✓ Beat-wise: {len(beat_final):,} rows")
print(f"✓ Beat Sheet Total: {beat_sheet_total:,.0f}")
print(f"✓ Match with Dump: {'✅ PERFECT' if abs(beat_sheet_total - dump_total) < 1 else '❌ MISMATCH'}")

