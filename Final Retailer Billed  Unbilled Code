    'SO DSM NAME': retailer_summary['STD_EMP_NAME'] if 'STD_EMP_NAME' in retailer_summary.columns else '',
    'BEAT CODE': retailer_summary['BEAT_CODE'] if 'BEAT_CODE' in retailer_summary.columns else '',
    'BEAT NAME': retailer_summary['STD_BEAT_NAME'] if 'STD_BEAT_NAME' in retailer_summary.columns else '',
    'S. NO.': retailer_summary['S_NO'],
    'RETAILER ID': retailer_summary['RETAILER_ID'],
    'RETAILER': retailer_summary['STD_RET_NAME'] if 'STD_RET_NAME' in retailer_summary.columns else retailer_summary['RETAILER_ID'],
