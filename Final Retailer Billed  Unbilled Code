for month in actual_months:
    retailer_final[month] = retailer_summary[month]
retailer_final['TOTAL BILLING'] = retailer_summary['TOTAL_BILLING']
retailer_final['BILLED / NOT BILLED'] = retailer_summary['BILLED_NOT_BILLED']
retailer_final['COUNT'] = retailer_summary['COUNT']
retailer_final['EMP STATUS'] = ''
retailer_final['BEAT STATUS'] = ''
retailer_final['RET STATUS'] = ''

retailer_sheet_total = retailer_final['TOTAL BILLING'].sum()
print(f"✓ Retailer-wise: {len(retailer_final):,} rows (as-is)")
print(f"✓ Retailer Sheet Total: {retailer_sheet_total:,.0f}")
